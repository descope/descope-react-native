{
  "name": "@descope/react-native-sdk",
  "version": "0.8.2",
  "description": "The Descope SDK for React-Native",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/src/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "!lib/typescript/example",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/test",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test example/src example-expo/src",
    "prepack": "bob build",
    "release": "release-it",
    "example": "yarn --cwd example",
    "build:android": "cd example/android && ./gradlew assembleDebug --no-daemon --console=plain -PreactNativeArchitectures=arm64-v8a",
    "build:ios": "cd example/ios && xcodebuild -workspace DescopeReactNativeExample.xcworkspace -scheme DescopeReactNativeExample -configuration Debug -sdk iphonesimulator COMPILER_INDEX_STORE_ENABLE=NO",
    "bootstrap": "yarn example && yarn install && yarn example pods",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build",
    "update:native": "./scripts/update-kotlin-sdk.sh && ./scripts/update-swift-sdk.sh"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "repository": "https://github.com/descope/descope-react-native",
  "author": "descope <support@descope.com> (https://descope.com)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/descope/descope-react-native/issues"
  },
  "homepage": "https://github.com/descope/descope-react-native#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@descope/core-js-sdk": "2.58.1",
    "base-64": "1.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "1.2.6",
    "@react-native-community/cli": "15.0.1",
    "@react-native-community/cli-platform-android": "15.0.1",
    "@react-native-community/cli-platform-ios": "15.0.1",
    "@react-native-community/eslint-config": "3.2.0",
    "@react-native/babel-preset": "0.78.0",
    "@release-it/conventional-changelog": "5.1.1",
    "@testing-library/react-native": "12.4.3",
    "@types/base-64": "1.0.2",
    "@types/jest": "29.5.14",
    "@types/react": "19.2.14",
    "del-cli": "6.0.0",
    "eslint": "9.20.0",
    "eslint-config-prettier": "10.0.1",
    "eslint-plugin-prettier": "5.2.3",
    "jest": "29.7.0",
    "pod-install": "0.1.39",
    "prettier": "3.5.0",
    "react": "19.0.0",
    "react-native": "0.78.0",
    "react-native-builder-bob": "0.20.4",
    "react-test-renderer": "19.0.0",
    "release-it": "15.11.0",
    "turbo": "1.12.3",
    "typescript": "5.7.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "engines": {
    "node": ">= 18.18.0"
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "angular"
      }
    }
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
